# ─── Database ─────────────────────────────────────────────────────────────────
DB_URI=postgresql://lersha:lersha@localhost:5432/lersha
DB_TABLE=farmer_data_all
FARMER_DATA_ALL=farmer_data_all
CANDIDATE_RESULT=candidate_result
CANDIDATE_RAW_DATA_TABLE=candidate_raw_data_table

# ─── Model Paths (relative to project root / backend/models/) ─────────────────
# FIXED: each model now reads from its own env var (was all reading XGB_MODEL_36)
XGB_MODEL_36=backend/models/xgboost_36_credit_score.pkl
RF_MODEL_36=backend/models/random_forest_36_credit_score.pkl
CAB_MODEL_36=backend/models/catboost_36_credit_score.pkl
FEATURE_COLUMN_36=backend/models/36_feature_columns.pkl
TARGET_COLUMN_36=backend/models/36_label_classes.pkl

# ─── LLM / RAG ────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-pro
GEMINI_API_KEY=your-gemini-api-key-here
EMBEDDER_MODEL=all-MiniLM-L6-v2
# Note: RAG tuning parameters (rag_top_k, rag_similarity_threshold) are configured
# in backend/config/hyperparams.yaml — not as environment variables.

# ─── RAG Prompt Versioning ────────────────────────────────────────────────────
# Controls which versioned prompt YAML is loaded from backend/prompts/.
# Prompt files must be named v{N}.yaml (e.g. v1.yaml, v2.yaml).
# Switch to a new version without redeploying — just update this value and restart.
PROMPT_VERSION=v1

# ─── API Security ─────────────────────────────────────────────────────────────
# Required: all /v1/ routes validate this header (X-API-Key: <value>)
API_KEY=your-secret-api-key-here

# ─── CLI / Frontend ───────────────────────────────────────────────────────────
# Used by backend/cli/ and Next.js frontend (server-side)
API_BASE_URL=http://localhost:8006

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_EXPERIMENT_NAME=Credit Scoring Model
# MLFLOW_TRACKING_URI defaults to mlruns/ directory if not set

# ─── Optional overrides ───────────────────────────────────────────────────────
# OUTPUT_DIR=output
# MODEL_DIR=backend/models
# LOG_DIR=logs
# LOG_FILE=logs/credit_scoring_model.log
# SHAP_PATH=output/shap_summary
# PROMPT_PATH=backend/prompts/prompts.yaml  # DEPRECATED — use PROMPT_VERSION instead

# ─── PostgreSQL (for docker-compose) ──────────────────────────────────────────
POSTGRES_USER=lersha
POSTGRES_PASSWORD=lersha
POSTGRES_DB=lersha

# ─── Redis / Celery ───────────────────────────────────────────────────────────
# Local dev (no Docker): use localhost
REDIS_URL=redis://localhost:6379/0
# Inside Docker Compose: use the service hostname
# REDIS_URL=redis://redis:6379/0

# Set to true to run Celery tasks synchronously in-process (no Redis or worker needed)
# Great for local `make api` runs.  Must be false/unset in production.
CELERY_TASK_ALWAYS_EAGER=true

# ─── MLflow artifact store ────────────────────────────────────────────────────
# S3 (default for production):
MLFLOW_S3_BUCKET=lersha-mlflow-artifacts
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# GCP alternative (comment out S3 vars and use this instead):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Secrets management ───────────────────────────────────────────────────────
# Development: set API_KEY and GEMINI_API_KEY directly in this file (above).
# Production:  use Docker secrets files instead:
#   echo -n "your-key" > secrets/api_key
#   echo -n "your-key" > secrets/gemini_api_key
# Cloud alternatives:
#   - AWS Secrets Manager: fetch at container start and write to /run/secrets/
#   - GCP Secret Manager: same pattern
#   - Kubernetes Secrets: mount as files at /run/secrets/

# ─── Docker Compose DB aliases (used by MLflow prod backend + backup service) ──
# These mirror POSTGRES_USER / POSTGRES_PASSWORD — set both in production
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}