# ─── Database ─────────────────────────────────────────────────────────────────
DB_URI=postgresql://lersha:lersha@localhost:5432/lersha
DB_TABLE=farmer_data_all
FARMER_DATA_ALL=farmer_data_all
CANDIDATE_RESULT=candidate_result
CANDIDATE_RAW_DATA_TABLE=candidate_raw_data_table

# ─── Model Paths (relative to project root / backend/models/) ─────────────────
# FIXED: each model now reads from its own env var (was all reading XGB_MODEL_36)
XGB_MODEL_36=backend/models/xgboost_36_credit_score.pkl
RF_MODEL_36=backend/models/random_forest_36_credit_score.pkl
CAB_MODEL_36=backend/models/catboost_36_credit_score.pkl
FEATURE_COLUMN_36=backend/models/36_feature_columns.pkl
TARGET_COLUMN_36=backend/models/36_label_classes.pkl

# ─── LLM / RAG ────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-1.5-pro
GEMINI_API_KEY=your-gemini-api-key-here
EMBEDDER_MODEL=all-MiniLM-L6-v2
CHROMA_DB_PATH=chroma_db

# ─── API Security ─────────────────────────────────────────────────────────────
# Required: all /v1/ routes validate this header (X-API-Key: <value>)
API_KEY=your-secret-api-key-here

# ─── UI ───────────────────────────────────────────────────────────────────────
# Used by ui/utils/api_client.py
API_BASE_URL=http://localhost:8000

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_EXPERIMENT_NAME=Credit Scoring Model
# MLFLOW_TRACKING_URI defaults to mlruns/ directory if not set

# ─── Optional overrides ───────────────────────────────────────────────────────
# OUTPUT_DIR=output
# MODEL_DIR=backend/models
# LOG_DIR=logs
# LOG_FILE=logs/credit_scoring_model.log
# SHAP_PATH=output/shap_summary
# PROMPT_PATH=backend/prompts/prompts.yaml

# ─── PostgreSQL (for docker-compose) ──────────────────────────────────────────
POSTGRES_USER=lersha
POSTGRES_PASSWORD=lersha
POSTGRES_DB=lersha

# ─── Redis / Celery ───────────────────────────────────────────────────────────
# Used by the Celery worker as broker and result backend
REDIS_URL=redis://redis:6379/0